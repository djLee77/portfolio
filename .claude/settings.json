{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "model": "sonnet",
    "env": {
        "ECC_HOOK_PROFILE": "standard",
        "MAX_THINKING_TOKENS": "10000"
    },
    "hooks": {
        "PreToolUse": [
            {
                "matcher": "Edit|Write",
                "hooks": [
                    {
                        "type": "command",
                        "command": "node \"c:/projects/portfolio/ecc/scripts/hooks/suggest-compact.js\"",
                        "timeout": 5
                    }
                ],
                "description": "Suggest manual compaction at logical intervals"
            }
        ],
        "PostToolUse": [
            {
                "matcher": "Edit",
                "hooks": [
                    {
                        "type": "command",
                        "command": "node \"c:/projects/portfolio/ecc/scripts/hooks/post-edit-console-warn.js\"",
                        "timeout": 5
                    }
                ],
                "description": "Warn about console.log statements after edits"
            },
            {
                "matcher": "Edit",
                "hooks": [
                    {
                        "type": "command",
                        "command": "node \"c:/projects/portfolio/ecc/scripts/hooks/post-edit-typecheck.js\"",
                        "timeout": 15
                    }
                ],
                "description": "TypeScript check after editing .ts/.tsx files"
            }
        ],
        "Stop": [
            {
                "matcher": "*",
                "hooks": [
                    {
                        "type": "command",
                        "command": "node \"c:/projects/portfolio/ecc/scripts/hooks/check-console-log.js\"",
                        "timeout": 5
                    }
                ],
                "description": "Check for console.log in modified files after each response"
            }
        ]
    }
}